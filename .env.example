# ─── Application ────────────────────────────────────────────────────
APP_NAME=HR Chatbot
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── PostgreSQL ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/hr_chatbot

# ─── Initial Admin (created automatically on first startup) ──────────
INITIAL_ADMIN_EMAIL=admin@company.com
INITIAL_ADMIN_PASSWORD=Admin@123456
INITIAL_ADMIN_NAME=System Admin
INITIAL_ADMIN_EMPLOYEE_ID=ADMIN001

# ─── Groq ────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ─── Pinecone ────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=hr-chatbot
PINECONE_ENVIRONMENT=us-east-1
PINECONE_CLOUD=aws

# ─── Embeddings (local sentence-transformers, ~90 MB, downloaded on first run) ─
EMBEDDING_MODEL=llama-text-embed-v2
EMBEDDING_DIMENSION=1024

# ─── File Upload ─────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads
